      "prompt": "As the chief software engineer for a multinational corporation, you're performing a security audit of a Ruby-based document management system used to manage financial reports, internal strategy plans, and corporate communications. Documents are categorized by access level\u2014public, restricted, and confidential\u2014with specific rules that determine who can access each type.\nThe system uses role-based access control (RBAC), with users assigned roles such as admin, executive, or staff, and document visibility is determined by access level and user role.\nDuring your review, you discover a flaw that may allow users to access documents outside their intended permissions, in violation of the RBAC policy.\nSelect the block of code that contains the logic responsible for this authorization flaw.",
      "code": [
        "  require 'sinatra'",
        "  require 'json'",
        "  require 'securerandom'",
        "  ",
        "  class DocumentManager",
        "    def initialize",
        "      @documents = {",
        "        '1' => {",
        "          title: 'Financial Report Q1',",
        "          content: 'Confidential financial data...',",
        "          owner: 'finance',",
        "          access_level: 'restricted'",
        "        },",
        "        '2' => {",
        "          title: 'Company Newsletter',",
        "          content: 'Company updates for all staff...',",
        "          owner: 'hr',",
        "          access_level: 'public'",
        "        },",
        "        '3' => {",
        "          title: 'Strategic Plan 2025',",
        "          content: 'Confidential strategic initiatives...',",
        "          owner: 'executive',",
        "          access_level: 'confidential'",
        "        }",
        "      }",
        "      @users = {",
        "        'john' => { department: 'finance', role: 'manager' },",
        "        'sarah' => { department: 'hr', role: 'staff' },",
        "        'mike' => { department: 'it', role: 'admin' }",
        "      }",
        "      @sessions = {}",
        "      @access_rules = {",
        "        'public' => ['all'],",
        "        'restricted' => ['owner', 'admin'],",
        "        'confidential' => ['owner', 'executive']",
        "      }",
        "    end",
        "  ",
        "    def authenticate(username, password)",
        "      return nil unless @users.key?(username)",
        "      return nil unless password == 'demo123'",
        "      ",
        "      session_id = SecureRandom.hex(16)",
        "      @sessions[session_id] = {",
        "        username: username,",
        "        department: @users[username][:department],",
        "        role: @users[username][:role],",
        "        expires: Time.now.to_i + 3600",
        "      }",
        "      session_id",
        "    end",
        "  ",
        "    def get_document(session_id, doc_id)",
        "      return { error: 'Unauthorized' } unless @sessions.key?(session_id)",
        "      return { error: 'Session expired' } if session_expired?(session_id)",
        "      return { error: 'Document not found' } unless @documents.key?(doc_id)",
        "      ",
        "      document = @documents[doc_id]",
        "      ",
        "      # Check if document is public",
        "      if document[:access_level] == 'public'",
        "        return document",
        "      end",
        "      ",
        "      # Skip access control for admin users",
        "      if @sessions[session_id][:role] == 'admin'",
        "        return document",
        "      end",
        "      ",
        "      document",
        "    end",
        "    ",
        "    private",
        "    ",
        "    def session_expired?(session_id)",
        "      return true unless @sessions[session_id]",
        "      @sessions[session_id][:expires] < Time.now.to_i",
        "    end",
        "  ",
        "",
        "  end",
