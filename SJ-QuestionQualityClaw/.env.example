# SJ-QuestionQualityClaw Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# --- Telegram Bot (required for notifications + commands) ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# --- LLM Backend ---
LLM_BACKEND=openrouter
SELECTED_MODEL=anthropic/claude-sonnet-4-20250514
OPENROUTER_API_KEY=your_openrouter_key

# --- GitHub (required for question repo sync) ---
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=astrorekcah
GITHUB_REPO_NAME=sj-question-bank

# --- Linear (required for ticket management) ---
LINEAR_API_KEY=your_linear_api_key
LINEAR_TEAM_ID=your_linear_team_id

# --- Database (optional — defaults to local docker-compose Postgres) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sjqqc_db
# DB_USER=sjqqc
# DB_PASSWORD=sjqqc
