{
  "path": "secure-coding/injection-flaws/code-injection/sc-if-JS-94-2",
  "title": "(JavaScript) Injection Flaws | Improper Control of Generation of Code ('Code Injection')",
  "parameters": {
    "programmingLanguage": [
      "javascript"
