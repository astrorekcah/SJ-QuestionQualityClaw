        "      pub name: String,",
        "      pub diagnosis: String,",
        "  }",
        "  ",
        "  #[derive(Clone, Debug, Serialize, Deserialize)]",
        "  pub struct SessionInfo {",
        "      pub user_id: String,",
        "      pub tenant_id: String,",
        "      pub expires_at: SystemTime,",
        "  }",
        "  ",
        "  pub struct AuthService {",
        "      users: Arc<RwLock<HashMap<String, User>>>,",
        "      sessions: Arc<RwLock<HashMap<String, SessionInfo>>>,",
        "      patient_data: Arc<RwLock<HashMap<String, Vec<PatientRecord>>>>,",
        "      access_control: Arc<RwLock<HashMap<String, Vec<String>>>>,",
        "  }",
        "  ",
        "  impl AuthService {",
        "      pub fn new() -> Self {",
        "          Self {",
        "              users: Arc::new(RwLock::new(HashMap::new())),",
        "              sessions: Arc::new(RwLock::new(HashMap::new())),",
        "              patient_data: Arc::new(RwLock::new(HashMap::new())),",
        "              access_control: Arc::new(RwLock::new(HashMap::new())),",
        "          }",
        "      }",
        "      ",
        "      pub fn generate_session_token(&self) -> String {",
        "          let mut bytes = [0u8; 32];",
        "          thread_rng().fill_bytes(&mut bytes);",
        "          general_purpose::URL_SAFE_NO_PAD.encode(bytes)",
        "      }",
        "      ",
        "      pub fn validate_session(&self, token: &str) -> Result<SessionInfo, Rejection> {",
        "          let sessions = self.sessions.read().unwrap();",
        "          ",
        "          if let Some(session) = sessions.get(token) {",
        "              if SystemTime::now() < session.expires_at {",
        "                  return Ok(session.clone());",
        "              } else {",
        "                  return Err(warp::reject::custom(AuthError::SessionExpired));",
        "              }",
        "          }",
        "          ",
        "          Err(warp::reject::custom(AuthError::InvalidSession))",
        "      }",
        "      ",
        "      pub async fn get_patient_records(&self, token: String, tenant_id_param: Option<String>) -> Result<impl Reply, Rejection> {",
        "          let session = self.validate_session(&token)?;",
        "          ",
        "          let tenant_id = if let Some(id) = tenant_id_param {",
        "              id",
        "          } else {",
        "              session.tenant_id.clone()",
        "          };",
        "          ",
        "          let data_guard = self.patient_data.read().unwrap();",
        "          let records = data_guard.get(&tenant_id).cloned().unwrap_or_default();",
        "          ",
        "          Ok(warp::reply::json(&records))",
        "      }",
        "      ",
        "      pub async fn create_patient_record(&self, token: String, mut record: PatientRecord) -> Result<impl Reply, Rejection> {",
        "          let session = self.validate_session(&token)?;",
        "          ",
        "          // Ensure record belongs to user's tenant",
        "          record.tenant_id = session.tenant_id.clone();",
        "          ",
        "          let mut data_guard = self.patient_data.write().unwrap();",
        "          ",
        "          let records = data_guard.entry(session.tenant_id.clone())",
        "              .or_insert_with(Vec::new);",
        "              ",
        "          records.push(record.clone());",
        "          ",
        "          Ok(warp::reply::json(&record))",
        "      }",
        "  }",
        "  ",
        "  #[derive(Debug)]",
        "  enum AuthError {",
        "      InvalidSession,",
