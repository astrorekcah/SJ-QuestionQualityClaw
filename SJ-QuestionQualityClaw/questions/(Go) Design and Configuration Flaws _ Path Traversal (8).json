      "prompt": "As a security architect for MedRecords, identify the line that contains a path traversal vulnerability in this file upload API. This vulnerability could allow attackers to write files outside the intended directory structure, potentially compromising patient data integrity and system security.",
      "code": [
        "package main",
        "",
        "  import (",
        "  \t\"errors\"",
        "  \t\"fmt\"",
        "  \t\"io/ioutil\"",
        "  \t\"net/http\"",
        "  \t\"os\"",
        "  \t\"path/filepath\"",
        "  \t\"strings\"",
        "",
        "  \t\"github.com/gin-gonic/gin\"",
        "  )",
        "",
        "  type FileHandler struct {",
        "  \twebRoot string",
        "  }",
        "",
        "  func NewFileHandler(rootPath string) *FileHandler {",
        "  \treturn &FileHandler{",
        "  \t\twebRoot: rootPath,",
        "  \t}",
        "  }",
        "",
        "  func (h *FileHandler) ServeFile(directory, filename string) (string, error) {",
        "  \tif strings.Contains(directory, \"..\") || strings.Contains(filename, \"..\") {",
        "  \t\treturn \"\", errors.New(\"Invalid path: directory traversal not allowed\")",
        "  \t}",
        "",
        "  \tfilePath := h.webRoot + \"/\" + directory + \"/\" + filename",
        "  \tcleanPath := filepath.Clean(filePath)",
        "  \tif !strings.HasPrefix(cleanPath, h.webRoot) {",
        "  \t\treturn \"\", errors.New(\"Access denied\")",
        "  \t}",
        "",
        "  \tcontent, err := ioutil.ReadFile(cleanPath)",
        "  \tif err != nil {",
        "  \t\treturn \"\", errors.New(\"File not found\")",
        "  \t}",
        "",
        "  \treturn string(content), nil",
        "  }",
        "",
        "  func (h *FileHandler) UploadFile(directory, filename, content string) error {",
        "  \tfilePath := filepath.Join(h.webRoot, directory, filename)",
        "",
        "  \tdir := h.webRoot + \"/\" + directory",
        "  \tcleanDir := filepath.Clean(dir)",
        "  \tif !strings.HasPrefix(cleanDir, h.webRoot) {",
        "  \t\treturn errors.New(\"Access denied\")",
        "  \t}",
        "",
        "  \tif err := os.MkdirAll(cleanDir, 0755); err != nil {",
        "  \t\treturn errors.New(\"Failed to create directory\")",
        "  \t}",
        "",
        "  \tif err := ioutil.WriteFile(filePath, []byte(content), 0644); err != nil {",
        "  \t\treturn errors.New(\"Failed to write file\")",
        "  \t}",
        "",
        "  \treturn nil",
        "  }",
        "",
        "  func (h *FileHandler) DeleteFile(directory, filename string) error {",
        "  \tif strings.Contains(directory, \"..\") || strings.Contains(filename, \"..\") {",
        "  \t\treturn errors.New(\"Invalid path: directory traversal not allowed\")",
        "  \t}",
        "",
        "  \tfilePath := h.webRoot + \"/\" + directory + \"/\" + filename",
        "  \tcleanPath := filepath.Clean(filePath)",
        "  \tif !strings.HasPrefix(cleanPath, h.webRoot) {",
        "  \t\treturn errors.New(\"Access denied\")",
        "  \t}",
        "  ",
        "  \tif err := os.Remove(cleanPath); err != nil {",
        "  \t\treturn errors.New(\"Failed to delete file\")",
        "  \t}",
        "  ",
        "  \treturn nil",
        "  }",
        "",
        "  func main() {",
        "  \trouter := gin.Default()",
        "  \thandler := NewFileHandler(\"/var/secure/medical\")",
        "",
        "  \trouter.POST(\"/upload/:dir/:file\", func(c *gin.Context) {",
        "  \t\tdir := c.Param(\"dir\")",
        "  \t\tfile := c.Param(\"file\")",
        "  \t\tcontent := c.PostForm(\"content\")",
        "",
        "  \t\terr := handler.UploadFile(dir, file, content)",
        "  \t\tif err != nil {",
        "  \t\t\tc.String(http.StatusInternalServerError, \"Upload failed: %v\", err)",
        "  \t\t\treturn",
        "  \t\t}",
        "",
        "  \t\tc.String(http.StatusOK, \"File uploaded successfully\")",
        "  \t})",
        "",
        "  \trouter.DELETE(\"/files/:dir/:file\", func(c *gin.Context) {",
        "  \t\tdir := c.Param(\"dir\")",
        "  \t\tfile := c.Param(\"file\")",
        "",
        "  \t\terr := handler.DeleteFile(dir, file)",
        "  \t\tif err != nil {",
        "  \t\t\tc.String(http.StatusInternalServerError, \"Delete failed: %v\", err)",
        "  \t\t\treturn",
        "  \t\t}",
        "",
        "  \t\tc.String(http.StatusOK, \"File deleted successfully\")",
        "  \t})",
        "",
        "  \tfmt.Println(\"Medical records server started on :8080\")",
        "  \trouter.Run(\":8080\")",
        "  }"
      ],
